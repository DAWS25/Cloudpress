{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "nodejs@20",
    "awscli2",
    "git"
  ],
  "shell": {
    "init_hook": [
      "echo '🚀 CloudPress Development Environment'",
      "cd cloudpress_frontend && npm install --silent 2>/dev/null || true",
      "node --version",
      "npm --version"
    ]
  }
}
